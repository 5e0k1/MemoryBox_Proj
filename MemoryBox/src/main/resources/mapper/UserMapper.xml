<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hogudeul.memorybox.mapper.UserMapper">

    <resultMap id="UserAccountMap" type="com.hogudeul.memorybox.model.UserAccount">
        <id column="user_id" property="userId"/>
        <result column="login_id" property="loginId"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="display_name" property="displayName"/>
        <result column="role" property="role"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="last_login_at" property="lastLoginAt"/>
        <result column="remember_token_hash" property="rememberTokenHash"/>
        <result column="remember_token_expires_at" property="rememberTokenExpiresAt"/>
        <result column="last_access_at" property="lastAccessAt"/>
        <result column="del_yn" property="delYn"/>
        <result column="del_at" property="delAt"/>
    </resultMap>

    <sql id="userColumns">
        user_id,
        login_id,
        password_hash,
        display_name,
        role,
        created_at,
        updated_at,
        last_login_at,
        remember_token_hash,
        remember_token_expires_at,
        last_access_at,
        del_yn,
        del_at
    </sql>

    <select id="findByLoginId" resultMap="UserAccountMap">
        SELECT
        <include refid="userColumns"/>
        FROM `USER`
        WHERE login_id = #{loginId}
        LIMIT 1
    </select>

    <select id="findByUserId" resultMap="UserAccountMap">
        SELECT
        <include refid="userColumns"/>
        FROM `USER`
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

    <select id="findByRememberTokenHash" resultMap="UserAccountMap">
        SELECT
        <include refid="userColumns"/>
        FROM `USER`
        WHERE remember_token_hash = #{rememberTokenHash}
          AND del_yn = 'N'
        LIMIT 1
    </select>

    <update id="updateLastLoginAt">
        UPDATE `USER`
        SET last_login_at = NOW(),
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="updateLastAccessAt">
        UPDATE `USER`
        SET last_access_at = NOW(),
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="updateRememberToken">
        UPDATE `USER`
        SET remember_token_hash = #{rememberTokenHash},
            remember_token_expires_at = #{rememberTokenExpiresAt},
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="clearRememberToken">
        UPDATE `USER`
        SET remember_token_hash = NULL,
            remember_token_expires_at = NULL,
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

    <update id="updatePasswordHash">
        UPDATE `USER`
        SET password_hash = #{passwordHash},
            updated_at = NOW()
        WHERE user_id = #{userId}
    </update>

</mapper>
